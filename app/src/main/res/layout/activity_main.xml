<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 🔝 Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111111"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@drawable/back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GARUDA"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textSize="20sp"
            android:textStyle="bold" />
        <ImageButton
            android:id="@+id/setting_Button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:scaleType="fitCenter"
            android:background="@null"
            android:src="@drawable/settings"
            android:layout_marginEnd="5dp"
            app:tint="#FFFFFF" />


        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/notificationButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@null"
                android:src="@drawable/notification"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/badgeCount"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|top"
                android:background="@drawable/badge_background"
                android:text="1"
                android:textSize="10sp"
                android:textColor="#FFF"
                android:gravity="center"
                android:visibility="gone"
                tools:ignore="SmallSp" />
        </FrameLayout>
    </LinearLayout>

    <!-- 🏷️ Section Title for Cards -->
    <TextView
        android:id="@+id/agentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Agent Dashboard"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="HardcodedText" />

    <!-- 🃏 Cards Section -->
    <HorizontalScrollView
        android:id="@+id/cardScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="12dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/agentTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 🔴 Total Registration -->
            <androidx.cardview.widget.CardView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true"
                app:cardPreventCornerOverlap="false">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_bg_red"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/form"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvTotalRegistration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginTop="4dp"
                            android:text="Total Registration"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ✅ Verified -->
            <androidx.cardview.widget.CardView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true"
                app:cardPreventCornerOverlap="false">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_bg_green"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/verified"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvVerified"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Verified"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ❌ Unverified -->
            <androidx.cardview.widget.CardView
                android:layout_width="160dp"
                android:layout_height="160dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardUseCompatPadding="true"
                app:cardPreventCornerOverlap="false">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/card_bg_brown"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/uncheck"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvUnverified"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:text="Unverified"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:layout_marginTop="3dp"
                            tools:ignore="HardcodedText" />
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 🏷️ Section Title for Registration Form -->
    <TextView
        android:id="@+id/registerServantsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Register Servants"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardScroll"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 📄 Registration Form in ScrollView -->
    <ScrollView
        android:id="@+id/formScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="12dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/registerServantsTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1E1E1E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 🔹 Top Row: Text Fields + Profile Picture -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- 📝 Name and Mobile -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/tvName"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginBottom="16dp"
                                android:background="@drawable/rounded_edittext"
                                android:hint="Name"
                                android:inputType="textPersonName"
                                android:padding="12dp"
                                android:textColor="#E0E0E0"
                                android:textColorHint="#B0B0B0" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <EditText
                                    android:id="@+id/mobile"
                                    android:layout_width="0dp"
                                    android:layout_height="48dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/rounded_edittext"
                                    android:hint="Mobile Number"
                                    android:inputType="phone"
                                    android:maxLength="10"
                                    android:padding="12dp"
                                    android:textColor="#E0E0E0"
                                    android:textColorHint="#B0B0B0" />

                                <ImageView
                                    android:id="@+id/mobile_verified_icon"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:paddingStart="8dp"
                                    android:src="@drawable/check"
                                    android:visibility="gone" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- 🖼 Profile Image -->
                        <FrameLayout
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center">

                            <ImageView
                                android:id="@+id/profile_picture"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/circle_background"
                                android:clipToOutline="true"
                                android:scaleType="centerCrop"
                                android:src="@drawable/profile" />

                            <ImageButton
                                android:id="@+id/btn_edit_image"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="bottom|end"
                                android:layout_margin="4dp"
                                android:background="@drawable/rounded_button"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="@android:color/white" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- 💼 Experience -->
                    <EditText
                        android:id="@+id/experience"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/rounded_edittext"
                        android:hint="Experience (in years)"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="#E0E0E0"
                        android:textColorHint="#B0B0B0" />

                    <!-- 📂 Category -->
                    <androidx.appcompat.widget.AppCompatSpinner
                        android:id="@+id/category"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/rounded_spinner"
                        android:drawableEnd="@drawable/ic_spinner_arrow"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:popupBackground="#2F2F2F"
                        android:spinnerMode="dropdown" />

                    <!-- 🚻 Gender & Availability -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingEnd="8dp">

                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/gender"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/rounded_spinner"
                                android:drawableEnd="@drawable/ic_spinner_arrow"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:popupBackground="#2F2F2F"
                                android:spinnerMode="dropdown" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <androidx.appcompat.widget.AppCompatSpinner
                                android:id="@+id/availability"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/rounded_spinner"
                                android:drawableEnd="@drawable/ic_spinner_arrow"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:popupBackground="#2F2F2F"
                                android:spinnerMode="dropdown" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 🏠 Address -->
                    <EditText
                        android:id="@+id/current_address"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/rounded_edittext"
                        android:hint="Current Address"
                        android:inputType="textPostalAddress"
                        android:padding="12dp"
                        android:textColor="#E0E0E0"
                        android:textColorHint="#B0B0B0" />
                    <EditText
                        android:id="@+id/area"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/rounded_edittext"
                        android:hint="Area"
                        android:inputType="textPostalAddress"
                        android:padding="12dp"
                        android:textColor="#E0E0E0"
                        android:textColorHint="#B0B0B0" />

                    <!-- 🆔 Aadhar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/aadhar_number"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/rounded_edittext"
                            android:hint="Aadhar Number"
                            android:inputType="number"
                            android:maxLength="12"
                            android:padding="12dp"
                            android:textColor="#E0E0E0"
                            android:textColorHint="#B0B0B0" />

                        <!-- ⬅️ Tick & Verified Label -->
                        <LinearLayout
                            android:id="@+id/aadhar_verified_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="8dp"
                            android:visibility="gone">

                            <ImageView
                                android:id="@+id/aadhar_verified_icon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="Verified"
                                android:src="@drawable/check" />

                            <TextView
                                android:id="@+id/aadhar_verified_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="4dp"
                                android:text="Verified"
                                android:textColor="#FFD700"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- ✅ CheckBox -->
                        <CheckBox
                            android:id="@+id/cb_verify_aadhar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text=""
                            android:contentDescription="Check to verify Aadhar" />

                    </LinearLayout>

                    <!-- ✅ Submit Button -->
                    <Button
                        android:id="@+id/submit_btn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="#D32F2F"
                        android:fontFamily="sans-serif-medium"
                        android:text="Register Servant"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registered Servants"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <!-- Search Input -->
                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:hint="Search by name or area"
                    android:background="@drawable/edittext_bg"
                    android:paddingStart="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:gravity="center_vertical"
                    android:inputType="text" />

                <!-- Add Button -->

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="#333333">

                <TextView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Mobile"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Verified"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <!-- 📋 RecyclerView inside ScrollView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewServants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>